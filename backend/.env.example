# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_NAME="AI Support Portal"
APP_VERSION="2.0.0"
DEBUG=true

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# Database (PostgreSQL recommended for production)
# Switch to SQLite for local dev: sqlite+aiosqlite:///./support.db
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/support_portal
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─────────────────────────────────────────────
# JWT Auth
# ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# Admin Bootstrap (only used on first startup)
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@support.com
ADMIN_PASSWORD=Admin@123

# ─────────────────────────────────────────────
# AI - Groq
# ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_CLASSIFIER_MODEL=llama3-70b-8192
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant
GROQ_KB_MODEL=llama-3.1-8b-instant

# ─────────────────────────────────────────────
# Knowledge Base / Vector Store
# ─────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
KB_SIMILARITY_THRESHOLD=0.6

# ─────────────────────────────────────────────
# File Uploads
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=application/pdf,text/plain

# ─────────────────────────────────────────────
# Optional: YouTube API (for KB video results)
# ─────────────────────────────────────────────
YOUTUBE_API_KEY=
